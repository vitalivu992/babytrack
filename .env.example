# BabyTrack environment configuration. Copy to .env and adjust.

# Server
PORT=8080

# Runtime mode: development | production
ENV=development

# PostgreSQL connection string
DB_URL=postgres://babytrack:babytrack@localhost:5432/babytrack?sslmode=disable

# JWT signing secret (use a long random value in production)
JWT_SECRET=change-me-to-a-long-random-secret
